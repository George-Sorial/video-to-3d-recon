# Track large binary artifacts with Git LFS.
# Run `git lfs install` once per machine, then `git lfs track` is already configured below —
# just make sure git-lfs is installed before committing files of these types.

*.mp4  filter=lfs diff=lfs merge=lfs -text
*.mov  filter=lfs diff=lfs merge=lfs -text
*.ply  filter=lfs diff=lfs merge=lfs -text
*.splat filter=lfs diff=lfs merge=lfs -text
*.pth  filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.npz  filter=lfs diff=lfs merge=lfs -text
*.pcd  filter=lfs diff=lfs merge=lfs -text
